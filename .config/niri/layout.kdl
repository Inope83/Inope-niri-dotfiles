// ==================== LAYOUT dengan Rounded Corners ====================
layout {
    gaps 16
    center-focused-column "never"
    
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }
    
    default-column-width { proportion 0.5; }
    
    // ========== FOCUS RING ==========
    focus-ring {
        width 3
        active-color "#cba6f7"
        inactive-color "#313244"
    }
    
    border {
        off
    }
    
    // ========== SHADOW ==========
    shadow {
        on
        softness 25
        spread 4
        offset x=0 y=4
        color "#00000080"
    }
}

// ========== ROUNDED CORNERS untuk Semua Window ==========
window-rule {
    geometry-corner-radius 8
    clip-to-geometry true
}